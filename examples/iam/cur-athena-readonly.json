{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "RunBoundedCURQueries",
      "Effect": "Allow",
      "Action": ["athena:StartQueryExecution", "athena:GetQueryExecution", "athena:GetQueryResults", "athena:StopQueryExecution"],
      "Resource": "arn:aws:athena:us-east-1:444455556666:workgroup/aws-cost-exporter"
    },
    {
      "Sid": "ReadCURCatalog",
      "Effect": "Allow",
      "Action": ["glue:GetDatabase", "glue:GetTable", "glue:GetPartitions"],
      "Resource": [
        "arn:aws:glue:us-east-1:444455556666:catalog",
        "arn:aws:glue:us-east-1:444455556666:database/billing",
        "arn:aws:glue:us-east-1:444455556666:table/billing/cur2"
      ]
    },
    {
      "Sid": "LocateCURBuckets",
      "Effect": "Allow",
      "Action": "s3:GetBucketLocation",
      "Resource": ["arn:aws:s3:::example-cur-bucket", "arn:aws:s3:::example-athena-results"]
    },
    {
      "Sid": "ListCURInput",
      "Effect": "Allow",
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::example-cur-bucket",
      "Condition": {"StringLike": {"s3:prefix": ["cur-prefix", "cur-prefix/*"]}}
    },
    {
      "Sid": "ListAthenaResults",
      "Effect": "Allow",
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::example-athena-results",
      "Condition": {"StringLike": {"s3:prefix": ["aws-cost-exporter", "aws-cost-exporter/*"]}}
    },
    {
      "Sid": "ListAthenaResultUploads",
      "Effect": "Allow",
      "Action": "s3:ListBucketMultipartUploads",
      "Resource": "arn:aws:s3:::example-athena-results"
    },
    {
      "Sid": "ReadCURObjects",
      "Effect": "Allow",
      "Action": "s3:GetObject",
      "Resource": "arn:aws:s3:::example-cur-bucket/cur-prefix/*"
    },
    {
      "Sid": "AccessAthenaResults",
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:PutObject", "s3:AbortMultipartUpload", "s3:ListMultipartUploadParts"],
      "Resource": "arn:aws:s3:::example-athena-results/aws-cost-exporter/*"
    }
  ]
}
