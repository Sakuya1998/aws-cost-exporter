{
  "__inputs": [{"name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus", "pluginName": "Prometheus"}],
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {"id": 1, "title": "Today accumulated", "type": "stat", "targets": [{"refId": "A", "expr": "sum by (target, currency) (aws_cost_daily_amount{job=~\"$job\",instance=~\"$instance\",target=~\"$target\",currency=~\"$currency\"})", "legendFormat": "{{target}} {{currency}}"}]},
    {"id": 2, "title": "Month to date", "type": "stat", "targets": [{"refId": "A", "expr": "sum by (target, currency) (aws_cost_month_to_date_amount{job=~\"$job\",instance=~\"$instance\",target=~\"$target\",currency=~\"$currency\"})", "legendFormat": "{{target}} {{currency}}"}]},
    {"id": 3, "title": "Estimated month end", "type": "stat", "targets": [{"refId": "A", "expr": "sum by (target, currency) (aws_cost_month_to_date_amount{job=~\"$job\",instance=~\"$instance\",target=~\"$target\",currency=~\"$currency\"}) - sum by (target, currency) (aws_cost_daily_amount{job=~\"$job\",instance=~\"$instance\",target=~\"$target\",currency=~\"$currency\"}) + sum by (target, currency) (aws_cost_month_forecast_mean_amount{job=~\"$job\",instance=~\"$instance\",target=~\"$target\",currency=~\"$currency\"})", "legendFormat": "{{target}} {{currency}}"}]},
    {"id": 4, "title": "Remaining-month forecast", "type": "stat", "targets": [{"refId": "A", "expr": "sum by (target, currency) (aws_cost_month_forecast_mean_amount{job=~\"$job\",instance=~\"$instance\",target=~\"$target\",currency=~\"$currency\"})", "legendFormat": "{{target}} {{currency}}"}]},
    {"id": 5, "title": "Data age", "type": "stat", "targets": [{"refId": "A", "expr": "max by (target) (aws_cost_exporter_cache_age_seconds{job=~\"$job\",instance=~\"$instance\",target=~\"$target\"})", "legendFormat": "{{target}}"}]},
    {"id": 6, "title": "Daily cost scrape history", "type": "timeseries", "targets": [{"refId": "A", "expr": "sum by (target, currency) (aws_cost_daily_amount{job=~\"$job\",instance=~\"$instance\",target=~\"$target\",currency=~\"$currency\"})", "legendFormat": "{{target}} {{currency}}"}]},
    {"id": 7, "title": "MTD and estimated month-end bounds", "type": "timeseries", "targets": [
      {"refId": "A", "expr": "sum by (target, currency) (aws_cost_month_to_date_amount{job=~\"$job\",instance=~\"$instance\",target=~\"$target\",currency=~\"$currency\"})", "legendFormat": "MTD {{target}} {{currency}}"},
      {"refId": "B", "expr": "sum by (target, currency) (aws_cost_month_to_date_amount{job=~\"$job\",instance=~\"$instance\",target=~\"$target\",currency=~\"$currency\"}) - sum by (target, currency) (aws_cost_daily_amount{job=~\"$job\",instance=~\"$instance\",target=~\"$target\",currency=~\"$currency\"}) + sum by (target, currency) (aws_cost_month_forecast_mean_amount{job=~\"$job\",instance=~\"$instance\",target=~\"$target\",currency=~\"$currency\"})", "legendFormat": "mean {{target}} {{currency}}"},
      {"refId": "C", "expr": "sum by (target, currency) (aws_cost_month_to_date_amount{job=~\"$job\",instance=~\"$instance\",target=~\"$target\",currency=~\"$currency\"}) - sum by (target, currency) (aws_cost_daily_amount{job=~\"$job\",instance=~\"$instance\",target=~\"$target\",currency=~\"$currency\"}) + sum by (target, currency) (aws_cost_month_forecast_lower_bound_amount{job=~\"$job\",instance=~\"$instance\",target=~\"$target\",currency=~\"$currency\"})", "legendFormat": "lower {{target}} {{currency}}"},
      {"refId": "D", "expr": "sum by (target, currency) (aws_cost_month_to_date_amount{job=~\"$job\",instance=~\"$instance\",target=~\"$target\",currency=~\"$currency\"}) - sum by (target, currency) (aws_cost_daily_amount{job=~\"$job\",instance=~\"$instance\",target=~\"$target\",currency=~\"$currency\"}) + sum by (target, currency) (aws_cost_month_forecast_upper_bound_amount{job=~\"$job\",instance=~\"$instance\",target=~\"$target\",currency=~\"$currency\"})", "legendFormat": "upper {{target}} {{currency}}"}
    ]},
    {"id": 8, "title": "Top 10 services", "type": "bargauge", "targets": [{"refId": "A", "expr": "topk by (target, currency) (10, sum by (target, currency, aws_service) (aws_cost_service_month_to_date_amount{job=~\"$job\",instance=~\"$instance\",target=~\"$target\",currency=~\"$currency\",aws_service=~\"$aws_service\"}))", "legendFormat": "{{target}} {{aws_service}} ({{currency}})"}]},
    {"id": 9, "title": "Top 10 regions", "type": "bargauge", "targets": [{"refId": "A", "expr": "topk by (target, currency) (10, sum by (target, currency, aws_region) (aws_cost_region_month_to_date_amount{job=~\"$job\",instance=~\"$instance\",target=~\"$target\",currency=~\"$currency\",aws_region=~\"$aws_region\"}))", "legendFormat": "{{target}} {{aws_region}} ({{currency}})"}]},
    {"id": 10, "title": "Top 10 accounts", "type": "bargauge", "targets": [{"refId": "A", "expr": "topk by (target, currency) (10, sum by (target, currency, linked_account_id) (aws_cost_account_month_to_date_amount{job=~\"$job\",instance=~\"$instance\",target=~\"$target\",currency=~\"$currency\",linked_account_id=~\"$linked_account_id\"}))", "legendFormat": "{{target}} {{linked_account_id}} ({{currency}})"}]},
    {"id": 11, "title": "Collector status", "type": "table", "targets": [
      {"refId": "A", "expr": "aws_cost_exporter_collector_up{job=~\"$job\",instance=~\"$instance\",target=~\"$target\"}", "legendFormat": "{{target}} {{collector}}"},
      {"refId": "B", "expr": "aws_cost_exporter_last_success_timestamp_seconds{job=~\"$job\",instance=~\"$instance\",target=~\"$target\"}", "legendFormat": "{{target}} {{collector}}"},
      {"refId": "C", "expr": "aws_cost_exporter_cache_age_seconds{job=~\"$job\",instance=~\"$instance\",target=~\"$target\"}", "legendFormat": "{{target}} {{collector}}"},
      {"refId": "D", "expr": "aws_cost_exporter_snapshot_series{job=~\"$job\",instance=~\"$instance\",target=~\"$target\"}", "legendFormat": "{{target}} {{collector}}"}
    ]},
    {"id": 12, "title": "Dimension overflow", "type": "table", "targets": [{"refId": "A", "expr": "sum by (target, dimension) (increase(aws_cost_exporter_dimension_overflow_values_total{job=~\"$job\",instance=~\"$instance\",target=~\"$target\"}[$__range]))", "legendFormat": "{{target}} {{dimension}}"}]},
    {"id": 13, "title": "AWS API requests", "type": "timeseries", "targets": [{"refId": "A", "expr": "sum by (target, operation, status) (rate(aws_cost_exporter_aws_api_requests_total{job=~\"$job\",instance=~\"$instance\",target=~\"$target\"}[5m]))", "legendFormat": "{{target}} {{operation}} {{status}}"}]},
    {"id": 14, "title": "AWS API error ratio", "type": "timeseries", "targets": [{"refId": "A", "expr": "sum by (target) (rate(aws_cost_exporter_aws_api_requests_total{job=~\"$job\",instance=~\"$instance\",target=~\"$target\",status=\"error\"}[5m])) / clamp_min(sum by (target) (rate(aws_cost_exporter_aws_api_requests_total{job=~\"$job\",instance=~\"$instance\",target=~\"$target\"}[5m])), 1e-9)", "legendFormat": "{{target}}"}]},
    {"id": 15, "title": "AWS API p99 latency", "type": "timeseries", "targets": [{"refId": "A", "expr": "histogram_quantile(0.99, sum by (target, le, operation) (rate(aws_cost_exporter_aws_api_request_duration_seconds_bucket{job=~\"$job\",instance=~\"$instance\",target=~\"$target\"}[5m])))", "legendFormat": "{{target}} {{operation}}"}]},
    {"id": 16, "title": "AWS API retries", "type": "timeseries", "targets": [{"refId": "A", "expr": "sum by (target, operation, reason) (rate(aws_cost_exporter_aws_api_retries_total{job=~\"$job\",instance=~\"$instance\",target=~\"$target\"}[5m]))", "legendFormat": "{{target}} {{operation}} {{reason}}"}]},
    {"id": 17, "title": "Skipped refreshes", "type": "timeseries", "targets": [{"refId": "A", "expr": "sum by (target, collector, reason) (rate(aws_cost_exporter_scheduler_skipped_runs_total{job=~\"$job\",instance=~\"$instance\",target=~\"$target\"}[5m]))", "legendFormat": "{{target}} {{collector}} {{reason}}"}]},
    {"id": 18, "title": "AWS Budgets", "type": "timeseries", "targets": [
      {"refId": "A", "expr": "aws_budget_limit_amount{job=~\"$job\",instance=~\"$instance\",target=~\"$target\",currency=~\"$currency\"}", "legendFormat": "limit {{target}} {{budget_name}}"},
      {"refId": "B", "expr": "aws_budget_actual_amount{job=~\"$job\",instance=~\"$instance\",target=~\"$target\",currency=~\"$currency\"}", "legendFormat": "actual {{target}} {{budget_name}}"},
      {"refId": "C", "expr": "aws_budget_forecasted_amount{job=~\"$job\",instance=~\"$instance\",target=~\"$target\",currency=~\"$currency\"}", "legendFormat": "forecast {{target}} {{budget_name}}"}
    ]},
    {"id": 19, "title": "Account metadata", "type": "table", "targets": [{"refId": "A", "expr": "aws_cost_account_info{job=~\"$job\",instance=~\"$instance\",target=~\"$target\"}", "legendFormat": "{{target}} {{linked_account_id}}"}]},
    {"id": 20, "title": "Cost data semantics", "type": "text", "options": {"mode": "markdown", "content": "Cost Explorer values are cached, eventually consistent, and target-scoped. Scrapes never call AWS."}, "targets": []}
  ],
  "refresh": "5m",
  "schemaVersion": 39,
  "tags": ["aws", "cost", "finops", "prometheus"],
  "templating": {"list": [
    {"name": "job", "label": "Job", "type": "query", "query": {"query": "label_values(aws_cost_daily_amount, job)"}, "multi": true, "includeAll": true, "allValue": ".*"},
    {"name": "instance", "label": "Instance", "type": "query", "query": {"query": "label_values(aws_cost_daily_amount{job=~\"$job\"}, instance)"}, "multi": true, "includeAll": true, "allValue": ".*"},
    {"name": "target", "label": "Target", "type": "query", "query": {"query": "label_values(aws_cost_daily_amount{job=~\"$job\",instance=~\"$instance\"}, target)"}, "multi": true, "includeAll": true, "allValue": ".*"},
    {"name": "currency", "label": "Currency", "type": "query", "query": {"query": "label_values(aws_cost_daily_amount{job=~\"$job\",instance=~\"$instance\",target=~\"$target\"}, currency)"}, "multi": true, "includeAll": true, "allValue": ".*"},
    {"name": "aws_service", "label": "AWS service", "type": "query", "query": {"query": "label_values(aws_cost_service_month_to_date_amount{job=~\"$job\",instance=~\"$instance\",target=~\"$target\",currency=~\"$currency\"}, aws_service)"}, "multi": true, "includeAll": true, "allValue": ".*"},
    {"name": "aws_region", "label": "AWS region", "type": "query", "query": {"query": "label_values(aws_cost_region_month_to_date_amount{job=~\"$job\",instance=~\"$instance\",target=~\"$target\",currency=~\"$currency\"}, aws_region)"}, "multi": true, "includeAll": true, "allValue": ".*"},
    {"name": "linked_account_id", "label": "Linked account", "type": "query", "query": {"query": "label_values(aws_cost_account_month_to_date_amount{job=~\"$job\",instance=~\"$instance\",target=~\"$target\",currency=~\"$currency\"}, linked_account_id)"}, "multi": true, "includeAll": true, "allValue": ".*"}
  ]},
  "time": {"from": "now-30d", "to": "now"},
  "timezone": "utc",
  "title": "AWS Cost Exporter",
  "uid": "aws-cost-exporter",
  "version": 2
}
