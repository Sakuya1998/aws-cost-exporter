{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Today accumulated",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}},
      "targets": [{"refId": "A", "expr": "sum by (currency) (aws_cost_daily_amount{job=~\"$job\",instance=~\"$instance\",currency=~\"$currency\"})", "legendFormat": "{{currency}}"}]
    },
    {
      "id": 2,
      "title": "Month to date",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}},
      "targets": [{"refId": "A", "expr": "sum by (currency) (aws_cost_month_to_date_amount{job=~\"$job\",instance=~\"$instance\",currency=~\"$currency\"})", "legendFormat": "{{currency}}"}]
    },
    {
      "id": 3,
      "title": "Estimated month end",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}},
      "targets": [{"refId": "A", "expr": "sum by (currency) (aws_cost_month_to_date_amount{job=~\"$job\",instance=~\"$instance\",currency=~\"$currency\"}) - sum by (currency) (aws_cost_daily_amount{job=~\"$job\",instance=~\"$instance\",currency=~\"$currency\"}) + sum by (currency) (aws_cost_month_forecast_mean_amount{job=~\"$job\",instance=~\"$instance\",currency=~\"$currency\"})", "legendFormat": "{{currency}}"}]
    },
    {
      "id": 4,
      "title": "Remaining-month forecast",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}},
      "targets": [{"refId": "A", "expr": "sum by (currency) (aws_cost_month_forecast_mean_amount{job=~\"$job\",instance=~\"$instance\",currency=~\"$currency\"})", "legendFormat": "{{currency}}"}]
    },
    {
      "id": 5,
      "title": "Data age",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 0},
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}},
      "targets": [{"refId": "A", "expr": "max(aws_cost_exporter_cache_age_seconds{job=~\"$job\",instance=~\"$instance\"})", "legendFormat": "oldest collector"}]
    },
    {
      "id": 6,
      "title": "Cost data semantics",
      "type": "text",
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 0},
      "options": {"mode": "markdown", "content": "**Currency safety:** never sum different currencies. Billing data can arrive late and be backfilled. Daily trends are Prometheus scrape history of the current UTC billing-day gauge, not exported historical billing rows. Forecast metrics include today through month end; estimates use MTD minus today plus forecast to avoid overlap."}
    },
    {
      "id": 7,
      "title": "Daily cost scrape history",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "targets": [{"refId": "A", "expr": "sum by (currency) (aws_cost_daily_amount{job=~\"$job\",instance=~\"$instance\",currency=~\"$currency\"})", "legendFormat": "daily {{currency}}"}]
    },
    {
      "id": 8,
      "title": "MTD and estimated month-end bounds",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "targets": [
        {"refId": "A", "expr": "sum by (currency) (aws_cost_month_to_date_amount{job=~\"$job\",instance=~\"$instance\",currency=~\"$currency\"})", "legendFormat": "MTD {{currency}}"},
        {"refId": "B", "expr": "sum by (currency) (aws_cost_month_to_date_amount{job=~\"$job\",instance=~\"$instance\",currency=~\"$currency\"}) - sum by (currency) (aws_cost_daily_amount{job=~\"$job\",instance=~\"$instance\",currency=~\"$currency\"}) + sum by (currency) (aws_cost_month_forecast_mean_amount{job=~\"$job\",instance=~\"$instance\",currency=~\"$currency\"})", "legendFormat": "estimated mean {{currency}}"},
        {"refId": "C", "expr": "sum by (currency) (aws_cost_month_to_date_amount{job=~\"$job\",instance=~\"$instance\",currency=~\"$currency\"}) - sum by (currency) (aws_cost_daily_amount{job=~\"$job\",instance=~\"$instance\",currency=~\"$currency\"}) + sum by (currency) (aws_cost_month_forecast_lower_bound_amount{job=~\"$job\",instance=~\"$instance\",currency=~\"$currency\"})", "legendFormat": "estimated lower {{currency}}"},
        {"refId": "D", "expr": "sum by (currency) (aws_cost_month_to_date_amount{job=~\"$job\",instance=~\"$instance\",currency=~\"$currency\"}) - sum by (currency) (aws_cost_daily_amount{job=~\"$job\",instance=~\"$instance\",currency=~\"$currency\"}) + sum by (currency) (aws_cost_month_forecast_upper_bound_amount{job=~\"$job\",instance=~\"$instance\",currency=~\"$currency\"})", "legendFormat": "estimated upper {{currency}}"}
      ]
    },
    {
      "id": 9,
      "title": "Top 10 services",
      "type": "bargauge",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 12},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "options": {"orientation": "horizontal", "displayMode": "gradient"},
      "targets": [{"refId": "A", "expr": "topk by (currency) (10, sum by (currency, aws_service) (aws_cost_service_month_to_date_amount{job=~\"$job\",instance=~\"$instance\",currency=~\"$currency\",aws_service=~\"$aws_service\"}))", "legendFormat": "{{aws_service}} ({{currency}})", "instant": true}]
    },
    {
      "id": 10,
      "title": "Top 10 regions",
      "type": "bargauge",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 12},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "options": {"orientation": "horizontal", "displayMode": "gradient"},
      "targets": [{"refId": "A", "expr": "topk by (currency) (10, sum by (currency, aws_region) (aws_cost_region_month_to_date_amount{job=~\"$job\",instance=~\"$instance\",currency=~\"$currency\",aws_region=~\"$aws_region\"}))", "legendFormat": "{{aws_region}} ({{currency}})", "instant": true}]
    },
    {
      "id": 11,
      "title": "Top 10 accounts",
      "type": "bargauge",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 12},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "options": {"orientation": "horizontal", "displayMode": "gradient"},
      "targets": [{"refId": "A", "expr": "topk by (currency) (10, sum by (currency, linked_account_id) (aws_cost_account_month_to_date_amount{job=~\"$job\",instance=~\"$instance\",currency=~\"$currency\",linked_account_id=~\"$linked_account_id\"}))", "legendFormat": "{{linked_account_id}} ({{currency}})", "instant": true}]
    },
    {
      "id": 12,
      "title": "Collector status",
      "type": "table",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 16, "x": 0, "y": 20},
      "targets": [
        {"refId": "A", "expr": "aws_cost_exporter_collector_up{job=~\"$job\",instance=~\"$instance\"}", "legendFormat": "up {{collector}}", "instant": true, "format": "table"},
        {"refId": "B", "expr": "aws_cost_exporter_last_success_timestamp_seconds{job=~\"$job\",instance=~\"$instance\"}", "legendFormat": "last success {{collector}}", "instant": true, "format": "table"},
        {"refId": "C", "expr": "aws_cost_exporter_cache_age_seconds{job=~\"$job\",instance=~\"$instance\"}", "legendFormat": "cache age {{collector}}", "instant": true, "format": "table"},
        {"refId": "D", "expr": "aws_cost_exporter_snapshot_series{job=~\"$job\",instance=~\"$instance\"}", "legendFormat": "series {{collector}}", "instant": true, "format": "table"}
      ]
    },
    {
      "id": 13,
      "title": "Dimension overflow",
      "type": "table",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 20},
      "targets": [{"refId": "A", "expr": "sum by (dimension) (increase(aws_cost_exporter_dimension_overflow_values_total{job=~\"$job\",instance=~\"$instance\"}[$__range]))", "legendFormat": "{{dimension}}", "instant": true, "format": "table"}]
    },
    {
      "id": 14,
      "title": "AWS API requests",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 5, "x": 0, "y": 28},
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []},
      "targets": [{"refId": "A", "expr": "sum by (operation, status) (rate(aws_cost_exporter_aws_api_requests_total{job=~\"$job\",instance=~\"$instance\"}[5m]))", "legendFormat": "{{operation}} {{status}}"}]
    },
    {
      "id": 15,
      "title": "AWS API error ratio",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 5, "x": 5, "y": 28},
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1}, "overrides": []},
      "targets": [{"refId": "A", "expr": "sum(rate(aws_cost_exporter_aws_api_requests_total{job=~\"$job\",instance=~\"$instance\",status=\"error\"}[5m])) / clamp_min(sum(rate(aws_cost_exporter_aws_api_requests_total{job=~\"$job\",instance=~\"$instance\"}[5m])), 1e-9)", "legendFormat": "error ratio"}]
    },
    {
      "id": 16,
      "title": "AWS API p99 latency",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 5, "x": 10, "y": 28},
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "targets": [{"refId": "A", "expr": "histogram_quantile(0.99, sum by (le, operation) (rate(aws_cost_exporter_aws_api_request_duration_seconds_bucket{job=~\"$job\",instance=~\"$instance\"}[5m])))", "legendFormat": "{{operation}} p99"}]
    },
    {
      "id": 17,
      "title": "AWS API retries",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 4, "x": 15, "y": 28},
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []},
      "targets": [{"refId": "A", "expr": "sum by (operation, reason) (rate(aws_cost_exporter_aws_api_retries_total{job=~\"$job\",instance=~\"$instance\"}[5m]))", "legendFormat": "{{operation}} {{reason}}"}]
    },
    {
      "id": 18,
      "title": "Skipped refreshes",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 5, "x": 19, "y": 28},
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []},
      "targets": [{"refId": "A", "expr": "sum by (collector, reason) (rate(aws_cost_exporter_scheduler_skipped_runs_total{job=~\"$job\",instance=~\"$instance\"}[5m]))", "legendFormat": "{{collector}} {{reason}}"}]
    }
  ],
  "refresh": "5m",
  "schemaVersion": 39,
  "tags": ["aws", "cost", "finops", "prometheus"],
  "templating": {
    "list": [
      {
        "name": "job",
        "label": "Job",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "query": {"query": "label_values(aws_cost_daily_amount, job)", "refId": "variable-job"},
        "refresh": 1,
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*"
      },
      {
        "name": "instance",
        "label": "Instance",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "query": {"query": "label_values(aws_cost_daily_amount{job=~\"$job\"}, instance)", "refId": "variable-instance"},
        "refresh": 1,
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*"
      },
      {
        "name": "currency",
        "label": "Currency",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "query": {"query": "label_values(aws_cost_daily_amount{job=~\"$job\",instance=~\"$instance\"}, currency)", "refId": "variable-currency"},
        "refresh": 1,
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*"
      },
      {
        "name": "aws_service",
        "label": "AWS service",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "query": {"query": "label_values(aws_cost_service_month_to_date_amount{job=~\"$job\",instance=~\"$instance\",currency=~\"$currency\"}, aws_service)", "refId": "variable-service"},
        "refresh": 1,
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*"
      },
      {
        "name": "aws_region",
        "label": "AWS region",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "query": {"query": "label_values(aws_cost_region_month_to_date_amount{job=~\"$job\",instance=~\"$instance\",currency=~\"$currency\"}, aws_region)", "refId": "variable-region"},
        "refresh": 1,
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*"
      },
      {
        "name": "linked_account_id",
        "label": "Linked account",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "query": {"query": "label_values(aws_cost_account_month_to_date_amount{job=~\"$job\",instance=~\"$instance\",currency=~\"$currency\"}, linked_account_id)", "refId": "variable-account"},
        "refresh": 1,
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*"
      }
    ]
  },
  "time": {"from": "now-30d", "to": "now"},
  "timepicker": {},
  "timezone": "utc",
  "title": "AWS Cost Exporter",
  "uid": "aws-cost-exporter",
  "version": 1,
  "weekStart": "monday"
}
